# ZXY Panel example environment file.
# Copy to /etc/zxy-panel/zxy-panel.env on the server and change values.

ZXY_PANEL_PORT=2053
ZXY_PANEL_HOST=0.0.0.0
ZXY_UPDATE_MANIFEST_URL=https://raw.githubusercontent.com/zoow1388-svg/zxy-panel/main/version.json

# Generate fresh values in production.
ZXY_ADMIN_USER=admin
ZXY_ADMIN_PASSWORD=change-me
ZXY_API_TOKEN=change-me
