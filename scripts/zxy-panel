#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="/etc/zxy-panel"
PANEL_INFO="${CONFIG_DIR}/panel.info"
APP_DIR="/opt/zxy-panel"

get_info() {
  local key="$1"
  if [[ -f "$PANEL_INFO" ]]; then
    grep -E "^${key}=" "$PANEL_INFO" | head -n1 | cut -d= -f2- || true
  fi
}

compose_cmd() {
  if docker compose version >/dev/null 2>&1; then
    echo "docker compose"
  elif command -v docker-compose >/dev/null 2>&1; then
    echo "docker-compose"
  else
    echo ""
  fi
}

install_mode() {
  get_info INSTALL_MODE || true
}

restart_api() {
  local mode
  mode="$(install_mode)"
  if [[ "$mode" == "fast" ]] || systemctl list-unit-files 2>/dev/null | grep -q '^zxy-panel-api.service'; then
    systemctl restart zxy-panel-api
    return
  fi
  local compose
  compose="$(compose_cmd)"
  if [[ -z "$compose" ]]; then
    echo "docker compose not found"
    exit 1
  fi
  cd "$APP_DIR"
  $compose restart zxy-panel-api >/dev/null
}

status_line() {
  local label="$1"
  local state="$2"
  local detail="${3:-}"
  if [[ "$state" == "ok" ]]; then
    printf "[OK]   %s" "$label"
  elif [[ "$state" == "warn" ]]; then
    printf "[WARN] %s" "$label"
  else
    printf "[FAIL] %s" "$label"
  fi
  if [[ -n "$detail" ]]; then
    printf " - %s" "$detail"
  fi
  printf "\n"
}

service_check() {
  local unit="$1"
  if systemctl is-active --quiet "$unit" 2>/dev/null; then
    status_line "$unit" ok "active running"
    return 0
  fi
  status_line "$unit" fail "not active"
  return 1
}

recent_xray_restart_count() {
  local lines
  lines=$(journalctl -u xray --since "3 minutes ago" --no-pager 2>/dev/null \
    | grep -E "Stopping Xray|Stopped Xray|Started Xray Service|Reading config|Xray .* started" || true)
  if [[ -z "$lines" ]]; then
    echo 0
    return 0
  fi
  printf '%s\n' "$lines" | wc -l | tr -d ' '
}


case "${1:-}" in
  info)
    if [[ ! -f "$PANEL_INFO" ]]; then
      echo "ZXY Panel info not found."
      exit 1
    fi
    USERNAME=$(get_info USERNAME)
    PASSWORD=$(get_info PASSWORD)
    PORT=$(get_info PORT)
    WEB_BASE_PATH=$(get_info WEB_BASE_PATH)
    ACCESS_URL=$(get_info ACCESS_URL)
    DATABASE=$(get_info DATABASE)
    VERSION=$(get_info VERSION)
    MODE=$(get_info INSTALL_MODE)
    echo "ZXY Panel Info"
    echo "=============================="
    printf "%-12s %s\n" "Version:" "${VERSION:-unknown}"
    printf "%-12s %s\n" "Mode:" "${MODE:-docker}"
    printf "%-12s %s\n" "Username:" "${USERNAME:-unknown}"
    printf "%-12s %s\n" "Password:" "${PASSWORD:-unknown}"
    printf "%-12s %s\n" "Port:" "${PORT:-unknown}"
    printf "%-12s %s\n" "WebPath:" "${WEB_BASE_PATH:-unknown}"
    printf "%-12s %s\n" "Database:" "${DATABASE:-unknown}"
    printf "%-12s %s\n" "Access URL:" "${ACCESS_URL:-unknown}"
    echo
    echo "Reminder: open the panel port and every node inbound port in your cloud firewall/security group."
    ;;

  status)
    MODE=$(install_mode)
    if [[ "$MODE" == "fast" ]] || systemctl list-unit-files 2>/dev/null | grep -q '^zxy-panel-api.service'; then
      systemctl status zxy-panel-api --no-pager -l 2>/dev/null || true
      echo
      systemctl status zxy-agent --no-pager -l 2>/dev/null || true
      echo
      systemctl status nginx --no-pager -l 2>/dev/null || true
    else
      COMPOSE=$(compose_cmd)
      if [[ -n "$COMPOSE" && -d "$APP_DIR" ]]; then
        cd "$APP_DIR"
        $COMPOSE ps || true
        echo
        systemctl status zxy-agent --no-pager -l 2>/dev/null || true
        systemctl status nginx --no-pager -l 2>/dev/null || true
      else
        echo "Docker Compose not found or app dir missing."
      fi
    fi
    ;;

  restart)
    MODE=$(install_mode)
    if [[ "$MODE" == "fast" ]] || systemctl list-unit-files 2>/dev/null | grep -q '^zxy-panel-api.service'; then
      systemctl restart zxy-panel-api 2>/dev/null || true
      systemctl restart zxy-agent 2>/dev/null || true
      systemctl restart nginx 2>/dev/null || true
    else
      COMPOSE=$(compose_cmd)
      if [[ -z "$COMPOSE" ]]; then
        echo "docker compose not found"
        exit 1
      fi
      cd "$APP_DIR"
      $COMPOSE restart
      systemctl restart zxy-agent 2>/dev/null || true
      systemctl restart nginx 2>/dev/null || true
    fi
    echo "ZXY Panel restarted."
    ;;

  logs)
    MODE=$(install_mode)
    if [[ "$MODE" == "fast" ]] || systemctl list-unit-files 2>/dev/null | grep -q '^zxy-panel-api.service'; then
      echo "Showing fast-mode logs. Ctrl+C to exit."
      journalctl -u zxy-panel-api -u zxy-agent -f --no-pager
    else
      COMPOSE=$(compose_cmd)
      if [[ -z "$COMPOSE" ]]; then
        echo "docker compose not found"
        exit 1
      fi
      cd "$APP_DIR"
      $COMPOSE logs --tail=120 -f
    fi
    ;;

  reset-password)
    if [[ ! -f "$PANEL_INFO" ]]; then
      echo "ZXY Panel info not found."
      exit 1
    fi
    DB_PATH="$APP_DIR/data/zxy-panel.json"
    if [[ ! -f "$DB_PATH" ]]; then
      echo "Database not found: $DB_PATH"
      exit 1
    fi
    NEW_PASSWORD=$(python3 - <<'PY_RANDOM'
import random, string
rng = random.SystemRandom()
alphabet = string.ascii_letters + string.digits
print(''.join(rng.choice(alphabet) for _ in range(12)), end='')
PY_RANDOM
)
    NEW_USERNAME="admin"
    python3 - "$DB_PATH" "$NEW_USERNAME" "$NEW_PASSWORD" <<'PY'
import base64, hashlib, json, os, sys
path, username, password = sys.argv[1], sys.argv[2], sys.argv[3]
with open(path, encoding='utf-8') as f:
    data=json.load(f)
admins=data.get('admins') or {}
if not admins:
    raise SystemExit('no admin users found')
first_key=next(iter(admins))
admin=admins[first_key]
admin['username']=username
salt=os.urandom(16)
dk=hashlib.pbkdf2_hmac('sha256', password.encode(), salt, 120000, dklen=32)
admin['password_hash']='pbkdf2-sha256$120000$%s$%s' % (
    base64.b64encode(salt).decode().rstrip('='),
    base64.b64encode(dk).decode().rstrip('='),
)
admin['enabled']=True
admins[first_key]=admin
data['admins']=admins
tmp=path+'.tmp'
with open(tmp,'w',encoding='utf-8') as f:
    json.dump(data,f,ensure_ascii=False,indent=2)
os.replace(tmp,path)
PY
    sed -i -E "s/^USERNAME=.*/USERNAME=${NEW_USERNAME}/" "$PANEL_INFO"
    sed -i -E "s/^PASSWORD=.*/PASSWORD=${NEW_PASSWORD}/" "$PANEL_INFO"
    restart_api
    echo "Password reset successfully."
    echo "Username: ${NEW_USERNAME}"
    echo "Password: ${NEW_PASSWORD}"
    ;;


  doctor)
    FAILS=0
    WARNS=0
    echo "ZXY Panel Doctor"
    echo "=============================="

    if [[ -f "$PANEL_INFO" ]]; then
      status_line "panel.info" ok "$PANEL_INFO"
    else
      status_line "panel.info" fail "missing: $PANEL_INFO"
      FAILS=$((FAILS+1))
    fi

    VERSION=$(get_info VERSION || true)
    MODE=$(get_info INSTALL_MODE || true)
    PORT=$(get_info PORT || true)
    WEB_BASE_PATH=$(get_info WEB_BASE_PATH || true)
    ACCESS_URL=$(get_info ACCESS_URL || true)
    printf "%-14s %s\n" "Version:" "${VERSION:-unknown}"
    printf "%-14s %s\n" "Mode:" "${MODE:-unknown}"
    printf "%-14s %s\n" "Panel port:" "${PORT:-unknown}"
    printf "%-14s %s\n" "WebPath:" "${WEB_BASE_PATH:-unknown}"
    printf "%-14s %s\n" "Access URL:" "${ACCESS_URL:-unknown}"
    echo

    for unit in zxy-panel-api zxy-agent xray nginx; do
      if ! service_check "$unit"; then
        FAILS=$((FAILS+1))
      fi
    done

    if command -v curl >/dev/null 2>&1 && curl -fsS http://127.0.0.1:8088/api/health >/dev/null 2>&1; then
      status_line "API health" ok "http://127.0.0.1:8088/api/health"
    else
      status_line "API health" fail "local API is not responding"
      FAILS=$((FAILS+1))
    fi

    if [[ -n "${PORT:-}" ]] && command -v curl >/dev/null 2>&1 && curl -fsS "http://127.0.0.1:${PORT}/api/health" >/dev/null 2>&1; then
      status_line "Nginx API proxy" ok "http://127.0.0.1:${PORT}/api/health"
    else
      status_line "Nginx API proxy" fail "panel port API proxy is not responding"
      FAILS=$((FAILS+1))
    fi

    if nginx -t >/dev/null 2>&1; then
      status_line "Nginx config" ok "syntax ok"
    else
      status_line "Nginx config" fail "nginx -t failed"
      FAILS=$((FAILS+1))
    fi

    if [[ -f /etc/zxy-panel/xray/config.json ]]; then
      status_line "Xray config" ok "/etc/zxy-panel/xray/config.json"
    else
      status_line "Xray config" warn "missing; create an inbound/client to generate it"
      WARNS=$((WARNS+1))
    fi

    if [[ -f "$APP_DIR/.env" ]] && grep -q '^ZXY_UPDATE_MANIFEST_URL=' "$APP_DIR/.env"; then
      MANIFEST=$(grep -E '^ZXY_UPDATE_MANIFEST_URL=' "$APP_DIR/.env" | head -n1 | cut -d= -f2-)
      status_line "Update manifest" ok "$MANIFEST"
    else
      status_line "Update manifest" warn "ZXY_UPDATE_MANIFEST_URL is not set"
      WARNS=$((WARNS+1))
    fi

    RESTART_LINES=$(recent_xray_restart_count || echo 0)
    if [[ "${RESTART_LINES:-0}" -gt 8 ]]; then
      status_line "Xray restart watch" warn "recent restart/config lines in 3 minutes: ${RESTART_LINES}"
      WARNS=$((WARNS+1))
    else
      status_line "Xray restart watch" ok "no abnormal restart loop detected"
    fi

    echo
    if [[ "$FAILS" -eq 0 ]]; then
      echo "Doctor result: PASS (${WARNS} warning(s))"
      exit 0
    fi
    echo "Doctor result: FAIL (${FAILS} failure(s), ${WARNS} warning(s))"
    echo "Tip: run 'zxy-panel logs' or 'journalctl -u zxy-panel-api -u zxy-agent -u xray -u nginx -n 120 --no-pager'."
    exit 1
    ;;

  update)
    MANIFEST_URL="${ZXY_UPDATE_MANIFEST_URL:-https://raw.githubusercontent.com/zoow1388-svg/zxy-panel/main/version.json}"
    echo "ZXY Panel Update Helper"
    echo "Manifest: ${MANIFEST_URL}"
    echo
    echo "This helper checks the remote version manifest. The web panel also provides: 系统升级 -> 检查更新。"
    if ! command -v python3 >/dev/null 2>&1; then
      echo "python3 not found. Please use the web panel or install python3."
      exit 1
    fi
    python3 - "$MANIFEST_URL" <<'PY_UPDATE'
import json, sys, urllib.request
url=sys.argv[1]
try:
    with urllib.request.urlopen(url, timeout=8) as r:
        data=json.loads(r.read().decode())
except Exception as e:
    print('Failed to fetch manifest:', e)
    sys.exit(1)
latest=data.get('latest') or data.get('version') or '-'
pkg=data.get('package') or '-'
dl=data.get('download_url') or '-'
sha=data.get('sha256') or ''
print('Latest:', latest)
print('Package:', pkg)
print('Download:', dl)
if sha:
    print('SHA256:', sha)
print('\nCopy this command to upgrade after confirming the package:')
print('cd /root && mkdir -p zxy-panel-upgrades && cd zxy-panel-upgrades && curl -L --fail -o %s %s && unzip -o %s && cd %s && bash deploy/install.sh 2>&1 | tee /root/zxy-panel-upgrade.log' % (pkg, dl, pkg, pkg[:-4] if pkg.endswith('.zip') else pkg))
PY_UPDATE
    ;;

  uninstall)
    MODE=$(install_mode)
    if [[ "$MODE" == "fast" ]] || systemctl list-unit-files 2>/dev/null | grep -q '^zxy-panel-api.service'; then
      systemctl stop zxy-panel-api 2>/dev/null || true
      systemctl disable zxy-panel-api 2>/dev/null || true
      rm -f /etc/systemd/system/zxy-panel-api.service
    fi
    COMPOSE=$(compose_cmd)
    if [[ -n "$COMPOSE" && -d "$APP_DIR" ]]; then
      cd "$APP_DIR"
      $COMPOSE down || true
    fi
    systemctl stop zxy-agent 2>/dev/null || true
    systemctl disable zxy-agent 2>/dev/null || true
    rm -f /etc/systemd/system/zxy-agent.service
    rm -f /etc/nginx/conf.d/zxy-panel.conf
    rm -f /usr/local/bin/zxy-panel
    systemctl daemon-reload || true
    systemctl restart nginx 2>/dev/null || true
    echo "ZXY Panel uninstalled."
    echo "Program directory kept: $APP_DIR"
    echo "Config directory kept:  $CONFIG_DIR"
    ;;

  *)
    echo "ZXY Panel CLI"
    echo
    echo "Usage:"
    echo "  zxy-panel info"
    echo "  zxy-panel status"
    echo "  zxy-panel restart"
    echo "  zxy-panel logs"
    echo "  zxy-panel reset-password"
    echo "  zxy-panel update"
    echo "  zxy-panel uninstall"
    ;;
esac
